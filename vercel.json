{
  "rewrites": [
    {
      "source": "/admin-control",
      "destination": "/admin-control/index.html"
    },
    {
      "source": "/admin-control/",
      "destination": "/admin-control/index.html"
    },
    {
      "source": "/admin-control/dashboard",
      "destination": "/admin-control/dashboard.html"
    },
    {
      "source": "/admin-control/dashboard/",
      "destination": "/admin-control/dashboard.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/content/site.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
